# ─── AUDITORS ────────────────────────────────────────────────────────────────
# How many independent auditors (simulated audit firms) to run in parallel.
# Each auditor runs 3 agents (logical-bugs, common-pitfalls, contextual).
# Range: 1–3. Default 1.
N_AUDITORS=3

# NOTE Ollama Models do not need API Key
# Auditor 1 — required. Default: local Ollama (free, unlimited).
AUDITOR_1_PROVIDER=ollama
AUDITOR_1_MODEL=qwen-junior-auditor
AUDITOR_1_API_KEY=

# Auditor 2 — required only if N_AUDITORS >= 2
AUDITOR_2_PROVIDER=ollama
AUDITOR_2_MODEL=qwen-senior-auditor
AUDITOR_2_API_KEY=

# Auditor 3 — required only if N_AUDITORS >= 3
AUDITOR_3_PROVIDER=ollama
AUDITOR_3_MODEL=glm-senior-auditor
AUDITOR_3_API_KEY=

# ─── SUPERVISOR ──────────────────────────────────────────────────────────────
# Validates and synthesizes all auditor findings into the final report.
# Use the strongest model you have access to for best dedup + severity scoring.
SUPERVISOR_PROVIDER=ollama
SUPERVISOR_MODEL=glm-supervisor
SUPERVISOR_API_KEY=

# ─── EMBEDDINGS ──────────────────────────────────────────────────────────────
# Used for RAG retrieval only. Must be consistent across ingest + audit runs.
# Changing this after ingest requires a full re-ingest (the checkpoint enforces this).
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_API_KEY=

# Fully offline option (no API key needed, requires Ollama + nomic-embed-text model):
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_API_KEY=

# ─── LOCAL SERVICES ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── WEB SERVER ──────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGIN=http://localhost:3000

# ─── DATA SOURCES ────────────────────────────────────────────────────────────
# Optional — improves Solodit scraper rate limits. Free key at solodit.cyfrin.io
SOLODIT_API_KEY=

# ─── PATHS ───────────────────────────────────────────────────────────────────
DATA_DIR=./data

# ─── LOGGING ─────────────────────────────────────────────────────────────────
# debug | info | warn | error
SENTINEL_LOG_LEVEL=info

# ─── RUNTIME ─────────────────────────────────────────────────────────────────
NODE_ENV=development